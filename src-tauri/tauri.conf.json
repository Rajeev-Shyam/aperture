{
  "$schema": "https://schema.tauri.app/config/v2/schema.json",
  "productName": "Aperture",
  "version": "0.1.0",
  "identifier": "dev.aperture",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../ui run dev",
    "beforeBuildCommand": "npm --prefix ../ui run build"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "Aperture",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false,
        "focus": false,
        "visible": true,
        "width": 1920,
        "height": 1080
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "externalBin": ["binaries/vlm-host", "binaries/stt-host"]
  }
}
